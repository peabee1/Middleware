# Supabase Postgres connection string.
#
# Use the POOLED (transaction-mode) connection for serverless functions.
# Get this from Supabase dashboard:
#   Settings → Database → Connection string → "Transaction" mode → URI
#
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# IMPORTANT: do NOT use the direct (5432) connection in serverless — it will exhaust connections.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
